# ====== 复制本文件为 .env 后填写 ======

# Web 登录密码（明文，首次启动时用它生成密码哈希存库；之后以库中哈希为准）
# 建议至少 12 位，含字母数字符号
LOGIN_PASSWORD=change-me-to-a-strong-password

# 服务端 scrypt 的 salt（任意长字符串，首次部署固定一个就别再改）
# 32 字节十六进制示例，可用命令生成： python -c "import secrets;print(secrets.token_hex(32))"
KDF_SALT=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# Web session 密钥（签名 cookie 用，任意长随机字符串）
SESSION_SECRET=change-me-to-a-long-random-session-secret

# ====== Turso（libSQL 远程数据库） ======
# 在 turso.tech 创建数据库后获取：
#   turso db show --url <db-name>
#   turso db tokens create <db-name>
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=change-me-to-your-turso-token

# ====== Upstash Redis KV（主密钥存储） ======
# 在 upstash.com 创建 Redis 数据库后，从 Rest API section 获取
KV_URL=https://your.upstash.io
KV_TOKEN=change-me-to-your-upstash-token

# 主密钥在 KV 的 TTL（秒），默认 30 天，不登录自动过期
MASTER_KEY_TTL=2592000